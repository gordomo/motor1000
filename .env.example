APP_NAME="Motor1000 Workshop"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080
APP_TIMEZONE=UTC
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_PORT_FORWARD=3306
DB_DATABASE=motor1000
DB_USERNAME=motor1000
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ─── Cache / Session / Queue ─────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PORT_FORWARD=6379

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@motor1000.local"
MAIL_FROM_NAME="${APP_NAME}"
MAILPIT_PORT=8025

# ─── Filesystem ──────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── WhatsApp (Abstraction layer - fill with your provider) ─────────────────
WHATSAPP_PROVIDER=twilio
WHATSAPP_FROM_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Alternative: WABA (Meta Cloud API)
WABA_PHONE_NUMBER_ID=
WABA_ACCESS_TOKEN=

# ─── Horizon ─────────────────────────────────────────────────────────────────
HORIZON_BALANCE_STRATEGY=auto
HORIZON_MAX_PROCESSES=10
HORIZON_MIN_PROCESSES=1

# ─── Filament ─────────────────────────────────────────────────────────────────
FILAMENT_FILESYSTEM_DISK=public

# ─── Vite ────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
