{
    "name": "motor1000/workshop",
    "description": "Motor1000 - Automotive Workshop Management Platform",
    "keywords": ["framework", "laravel", "saas", "workshop"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10",
        "laravel/horizon": "^5.29",
        "laravel/breeze": "^2.3",
        "filament/filament": "^3.3",
        "livewire/livewire": "^3.5",
        "spatie/laravel-permission": "^6.10",
        "spatie/laravel-activitylog": "^4.9",
        "spatie/laravel-medialibrary": "^11.11",
        "spatie/laravel-tags": "^4.8",
        "spatie/laravel-query-builder": "^6.2",
        "barryvdh/laravel-dompdf": "^3.1",
        "maatwebsite/excel": "^3.1",
        "twilio/sdk": "^8.3",
        "guzzlehttp/guzzle": "^7.9",
        "league/flysystem-aws-s3-v3": "^3.29"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.18",
        "laravel/sail": "^1.38",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^3.7",
        "pestphp/pest-plugin-laravel": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
